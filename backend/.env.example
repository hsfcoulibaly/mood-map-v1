# Copy to .env and fill in values. Never commit .env.

# GCP Cloud Run + Cloud SQL: set CLOUD_SQL_CONNECTION_NAME=project:region:instance
# and attach the instance on the Cloud Run service. DB_HOST is then unused.
# CLOUD_SQL_CONNECTION_NAME=

DB_HOST=127.0.0.1
DB_USER=moodmap
DB_PASSWORD=
DB_NAME=moodmap

# Required in production: at least 32 random bytes (openssl rand -hex 32)
JWT_SECRET=

# Access token lifetime in minutes (default 10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated origins for browser clients (native apps ignore CORS).
# Example: https://admin.moodmap.example
CORS_ORIGINS=

# Set to production on a public deployment (stricter defaults)
APP_ENV=development

# OAuth 2.0 "Web client" ID from Google Cloud Console (used to verify Android ID tokens)
GOOGLE_WEB_CLIENT_ID=
