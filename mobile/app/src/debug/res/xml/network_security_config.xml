<?xml version="1.0" encoding="utf-8"?>
<!-- Debug only: allow HTTP to any host (10.0.2.2 for emulator, LAN IP for a physical device).
     Release builds use main/network_security_config.xml (HTTPS only). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
